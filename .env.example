# AuraFlow Platform — Environment Variables
# Copy to .env.local and fill in values

# ═══ SUPABASE ═══
# Get from: supabase.com/dashboard/project/bfzdcyuyilesubtgbhdc/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://bfzdcyuyilesubtgbhdc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ═══ ANTHROPIC (Claude AI Chat) ═══
# Get from: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ═══ APIFY (Data Scraping) ═══
# Get from: apify.com → Settings → Integrations → API tokens
APIFY_API_TOKEN=

# ═══ GOOGLE (PageSpeed + Maps) ═══
# Get from: console.cloud.google.com → APIs → Credentials
# Optional — works without key but rate limited
GOOGLE_API_KEY=

# ═══ N8N WEBHOOKS ═══
N8N_WEBHOOK_BASE=https://aurabazaar.app.n8n.cloud/webhook

# ═══ APP ═══
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://app.auraflowusa.com
